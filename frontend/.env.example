# Google Custom Search API Configuration
# Para obter estas credenciais:
# 1. Vá para https://console.cloud.google.com/
# 2. Crie um projeto ou use um existente
# 3. Habilite a "Custom Search API"
# 4. Crie um "Custom Search Engine" em https://cse.google.com/
# 5. Copie o API Key e o Search Engine ID (CX)

REACT_APP_GOOGLE_API_KEY=your_google_api_key_here
REACT_APP_GOOGLE_CX=your_search_engine_id_here

# Configurações da API Religiosa
# OPÇÕES DE IA PARA USAR:

# 1. OpenAI GPT-4 (Mais completo)
# REACT_APP_RELIGIOUS_API_URL=https://api.openai.com/v1
# REACT_APP_RELIGIOUS_API_KEY=sk-your-openai-key-here
# REACT_APP_AI_MODEL=gpt-4

# 2. Google Gemini (Mais barato)
# REACT_APP_RELIGIOUS_API_URL=https://generativelanguage.googleapis.com/v1beta
# REACT_APP_RELIGIOUS_API_KEY=your-google-ai-key-here
# REACT_APP_AI_MODEL=gemini-pro

# 3. Anthropic Claude (Mais seguro)
# REACT_APP_RELIGIOUS_API_URL=https://api.anthropic.com/v1
# REACT_APP_RELIGIOUS_API_KEY=sk-ant-your-key-here
# REACT_APP_AI_MODEL=claude-3-sonnet

# 4. API Religiosa Especializada (se existir)
# REACT_APP_RELIGIOUS_API_URL=https://api.religious-ai.com/v1
# REACT_APP_RELIGIOUS_API_KEY=sua_chave_de_api_aqui

# CONFIGURAÇÃO ATUAL (usando fallback local):
REACT_APP_RELIGIOUS_API_URL=https://api.openai.com/v1
REACT_APP_RELIGIOUS_API_KEY=
REACT_APP_AI_MODEL=gpt-4

# Configurações do Ambiente
REACT_APP_ENVIRONMENT=development
REACT_APP_DEBUG=true

# Configurações da Aplicação
REACT_APP_NAME=IA Assembleia de Deus
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Assistente espiritual baseado na Palavra de Deus
